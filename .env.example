# WalletConnect Project ID (get from https://cloud.walletconnect.com/)
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Network Configuration
VITE_NETWORK=sepolia  # Supported: "sepolia" or "mainnet"

# Subgraph Configuration
VITE_SUBGRAPH_AUTH_TOKEN=your_token_here

# Mode Configuration
# Set to "true" for claim-only mode (only claim role, no spending limits)
# Leave empty or set to "false" for full mode (execute/transfer roles with spending limits)
VITE_CLAIM_ONLY=false
